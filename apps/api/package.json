{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@hono/node-server": "^1.13.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "bwip-js": "^4.11.1",
    "drizzle-orm": "^0.38.0",
    "firebase-admin": "^13.10.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "meilisearch": "^0.44.0",
    "pdfkit": "^0.15.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "shared": "workspace:*",
    "twilio": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/ldapjs": "^3.0.6",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
